{
  "mcpInterceptors": [
    "my_package.mcp.auth:build_auth_interceptor"
  ],
  "mcpServers": {
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    },
    "business-api": {
      "enabled": false,
      "type": "stdio",
      "command": "python",
      "args": [
        "/absolute/path/to/skills/public/project-builder/scripts/business_api_mcp_server.py"
      ],
      "env": {
        "BUSINESS_API_BASE_URL": "$BUSINESS_API_BASE_URL",
        "BUSINESS_API_TOKEN": "$BUSINESS_API_TOKEN"
      },
      "description": "Business API MCP server template used by project-builder skill"
    }
  },
  "skills": {}
}
